{
  "name": "m365-renew-v2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .build/ .serverless/ dist/",
    "build": "tsc && npm run test",
    "test": "vitest run",
    "predeploy": "npm run clean && npm run prettier && npm run lint && npm run build",
    "deploy": "serverless deploy",
    "prettier": "prettier --write .",
    "lint": "eslint --ignore-pattern dist/ --ignore-pattern .serverless/ --ext .ts,.tsx --fix .",
    "tsc": "tsc --noemit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1066.x",
    "@aws-sdk/client-sns": "^3.1061.x",
    "@aws-sdk/lib-dynamodb": "^3.1061.x",
    "@sparticuz/chromium": "^149.0.x",
    "puppeteer-core": "^24.42.x",
    "swagger-ui-dist": "^5.32.x",
    "uuid": "^14.0.x"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.x",
    "@types/node": "^25.9.x",
    "eslint": "^10.4.x",
    "eslint-config-prettier": "^10.1.x",
    "eslint-plugin-prettier": "^5.5.x",
    "globals": "^17.6.x",
    "prettier": "^3.8.x",
    "serverless": "^4.37.x",
    "serverless-localstack": "^1.4.0",
    "typescript": "^6.0.x",
    "typescript-eslint": "^8.61.x",
    "vitest": "^4.1.8"
  }
}
