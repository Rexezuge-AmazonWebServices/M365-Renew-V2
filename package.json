{
  "name": "m365-renew-v2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .build/ .serverless/ dist/",
    "build": "tsc && npm run test",
    "test": "vitest run",
    "predeploy": "npm run clean && npm run prettier && npm run lint && npm run build",
    "deploy": "serverless deploy",
    "prettier": "prettier --write .",
    "lint": "eslint --ignore-pattern dist/ --ignore-pattern .serverless/ --ext .ts,.tsx --fix .",
    "tsc": "tsc --noemit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1093.x",
    "@aws-sdk/client-sns": "^3.1093.x",
    "@aws-sdk/lib-dynamodb": "^3.1088.x",
    "@sparticuz/chromium": "^149.0.x",
    "puppeteer-core": "^25.3.x",
    "swagger-ui-dist": "^5.32.x",
    "uuid": "^14.0.x"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.x",
    "@types/node": "^26.1.x",
    "eslint": "^10.6.x",
    "eslint-config-prettier": "^10.1.x",
    "eslint-plugin-prettier": "^5.5.x",
    "globals": "^17.7.x",
    "prettier": "^3.9.x",
    "serverless": "^4.39.x",
    "serverless-localstack": "^1.4.0",
    "typescript": "^6.0.x",
    "typescript-eslint": "^8.64.x",
    "vitest": "^4.1.10"
  }
}
