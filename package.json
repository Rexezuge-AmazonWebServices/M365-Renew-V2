{
  "name": "m365-renew-v2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .build/ .serverless/ dist/",
    "build": "tsc",
    "predeploy": "npm run clean && npm run prettier && npm run lint && npm run build",
    "deploy": "serverless deploy",
    "prettier": "prettier --write .",
    "lint": "eslint --ignore-pattern dist/ --ignore-pattern .serverless/ --ext .ts,.tsx --fix .",
    "tsc": "tsc --noemit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.975.0",
    "@aws-sdk/client-sns": "^3.975.0",
    "@aws-sdk/lib-dynamodb": "^3.975.0",
    "@sparticuz/chromium": "^143.0.4",
    "otplib": "^13.2.0",
    "puppeteer-core": "^24.36.0",
    "swagger-ui-dist": "^5.31.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^25.0.10",
    "eslint": "^9.39.x",
    "eslint-config-prettier": "^10.1.x",
    "eslint-plugin-prettier": "^5.5.x",
    "globals": "^17.1.x",
    "prettier": "^3.8.x",
    "serverless": "^4.31.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.x"
  }
}
