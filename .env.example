# AES encryption key for storing credentials (generate using /api/admin/generate-key)
AES_ENCRYPTION_KEY=your_base64_encoded_key_here

# Email address for SNS or MailMeow notifications
NOTIFICATION_EMAIL=your-email@example.com

# Notification provider: console, sns, or mailmeow. SNS resources deploy only when this is sns.
NOTIFICATION_PROVIDER=sns

# MailMeow configuration, required when NOTIFICATION_PROVIDER=mailmeow
MAIL_MEOW_BASE_URL=https://mail-meow.example.com
MAIL_MEOW_API_KEY=your_mail_meow_api_key_here

# Base URL for TOTP generation server (without trailing slash)
TOTP_SERVER_BASE_URL=https://totp.example.com

# Optional URL that returns the Lambda external IPv4 or IPv6 address as plain text
EXTERNAL_IP_LOOKUP_URL=https://ip.example.com
